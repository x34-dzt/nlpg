# App database (stores users, connections, conversations, widgets)
DATABASE_URL=postgresql://user:password@localhost:5432/nlpg

# Demo ecommerce database (pre-seeded with Faker.js data)
DEMO_DB_URL=postgresql://user:password@localhost:5432/demo_store

# JWT signing secret
JWT_SECRET=change-me-to-a-random-string

# LLM API keys — at least one is required
GOOGLE_GENERATIVE_AI_API_KEY=
OPENROUTER_API_KEY=

# Optional overrides
PORT=3001
GEMINI_MODEL=gemini-3.1-flash-lite-preview
AI_MODEL=qwen/qwen3.6-plus:free
